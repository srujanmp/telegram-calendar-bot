# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here   # get from @userinfobot — leave blank to allow everyone

# Grok (xAI)
GROK_API_KEY=your_grok_api_key_here

# Google Calendar
GOOGLE_CALENDAR_ID=primary                   # or a specific calendar ID from calendar settings
GOOGLE_TOKEN_JSON=                           # base64-encoded token.json — fill after local auth (see README)

# Path where token is saved inside the container (Railway Volume mount path)
TOKEN_PATH=/data/token.json
